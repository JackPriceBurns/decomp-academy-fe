# --- Auth + progress + compile (browser-safe, shipped in the bundle) ---
# AWS Cognito user pool the app authenticates against, and the API behind the
# custom domain that stores server-side progress AND runs the MWCC compile/grading
# service (proxied server-side via /api/target and /api/check, so lesson solutions
# never reach the browser). The app client is public (no secret, SRP flow), so the
# pool/client IDs are safe to expose.
#
# Leave NEXT_PUBLIC_API_URL unset to compile locally against ../sfa during `next dev`.
NEXT_PUBLIC_AWS_REGION=eu-west-1
NEXT_PUBLIC_COGNITO_USER_POOL_ID=eu-west-1_roj6Pz3OE
NEXT_PUBLIC_COGNITO_CLIENT_ID=7fnklfk6k6c3udal7m19tgfheg
NEXT_PUBLIC_API_URL=https://api.decomp-academy.dev
